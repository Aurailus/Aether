{
  "name": "aether",
  "version": "0.1.0",
  "description": "",
  "main": "./dist/main.js",
  "scripts": {
    "build": "npm run build-main && npm run build-renderer",
    "build-main": "cross-env NODE_ENV=production webpack --config webpack-main-PROD-config.js",
    "build-renderer": "cross-env NODE_ENV=production webpack --config webpack-renderer-PROD-config.js",
    "start-dev": "cross-env START_HOT=1 npm run start-renderer-dev",
    "start-main-dev": "webpack --config webpack-main-config.js && electron ./dist/main.js",
    "start-renderer-dev": "webpack-dev-server --config webpack-renderer-DEV-config.js",
    "prestart": "npm run build",
    "start": "electron .",
    "lint": "tslint '{src,test,mocks}/**/*.{ts,tsx}' --project ./tsconfig.json",
    "test": "jest '(\\/test\\/(?!e2e/)).*'",
    "pretest:e2e": "npm run build",
    "test:e2e": "jest '(\\/test\\/e2e/).*'",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testRegex": "(/test/.+\\.spec)\\.tsx?$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "json",
      "node"
    ],
    "moduleNameMapper": {
      "\\.(jpe?g|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/mocks/fileMock.js",
      "\\.(s?css|sass)$": "<rootDir>/mocks/styleMock.js"
    }
  },
  "build": {
    "productName": "AetherMail",
    "appId": "com.aurailus.aethermail",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/",
      "node_modules/",
      "package.json"
    ],
    "linux": {
      "target": "deb",
      "category": "Network"
    },
    "win": {
      "target": "nsis"
    }
  },
  "author": {
    "name": "Nicole Collings",
    "email": "me@auri.xyz"
  },
  "license": "SEE LICENSE",
  "bugs": {
    "url": "https://github.com/Aurailus/Aether/issues"
  },
  "homepage": "https://github.com/Aurailus/Aether",
  "devDependencies": {
    "@babel/core": "^7.8.3",
    "@babel/plugin-proposal-class-properties": "^7.8.3",
    "@babel/polyfill": "^7.8.3",
    "@babel/preset-env": "^7.8.3",
    "@babel/preset-react": "^7.8.3",
    "@babel/preset-typescript": "^7.8.3",
    "@hot-loader/react-dom": "^16.11.0",
    "@types/electron-devtools-installer": "^2.2.0",
    "@types/jest": "^24.9.1",
    "@types/node": "^13.9.5",
    "@types/react": "^16.9.19",
    "@types/react-dom": "^16.9.5",
    "@types/react-hot-loader": "^4.1.1",
    "@types/react-redux": "^7.1.7",
    "@types/react-test-renderer": "^16.9.2",
    "@types/webdriverio": "^4.8.7",
    "@types/webpack": "^4.41.9",
    "@types/webpack-env": "^1.15.0",
    "@types/mailparser": "^2.7.0",
    "@types/quoted-printable": "^0.2.2",
    "@types/react-addons-css-transition-group": "^15.0.5",
    "babel-loader": "^8.0.6",
    "cross-env": "^5.2.1",
    "css-loader": "^2.1.1",
    "electron": "^3.1.13",
    "electron-builder": "^20.44.4",
    "electron-devtools-installer": "^2.2.4",
    "electron-rebuild": "^1.10.1",
    "file-loader": "^3.0.1",
    "fork-ts-checker-webpack-plugin": "^1.6.0",
    "html-webpack-plugin": "^3.2.0",
    "husky": "^2.7.0",
    "image-webpack-loader": "^4.6.0",
    "jest": "^24.9.0",
    "lint-staged": "^8.2.1",
    "node-sass": "^4.13.1",
    "prettier": "^1.19.1",
    "react-hot-loader": "^4.12.19",
    "react-test-renderer": "^16.12.0",
    "redux-devtools-extension": "^2.13.5",
    "sass-loader": "^7.3.1",
    "source-map-loader": "^0.2.4",
    "spectron": "^5.0.0",
    "style-loader": "^0.23.1",
    "ts-jest": "^24.3.0",
    "ts-node": "^8.8.1",
    "tslint": "^5.20.1",
    "tslint-config-airbnb": "^5.11.2",
    "tslint-config-prettier": "^1.18.0",
    "tslint-react": "^4.2.0",
    "typescript": "^3.8.3",
    "webpack": "^4.41.5",
    "webpack-cli": "^3.3.10",
    "webpack-dev-server": "^3.10.1",
    "webpack-merge": "^4.2.2"
  },
  "dependencies": {
    "@types/jsdom": "^16.2.0",
    "@types/marked": "^0.7.3",
    "@types/turndown": "^5.0.0",
    "imap": "^0.8.19",
    "jsdom": "^16.2.2",
    "knex": "^0.20.13",
    "mailparser": "^2.7.7",
    "marked": "^0.8.2",
    "quoted-printable": "^1.0.1",
    "react": "^16.12.0",
    "react-addons-css-transition-group": "^15.6.2",
    "react-dom": "^16.12.0",
    "react-electron-web-view": "^2.0.1",
    "react-redux": "^7.1.3",
    "react-transition-group": "^4.3.0",
    "sqlite3": "^4.1.1",
    "tedious": "^8.2.0",
    "turndown": "^6.0.0"
  }
}
