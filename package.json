{
  "name": "aether",
  "version": "0.1.0",
  "description": "",
  "main": "./dist/main.js",
  "scripts": {
    "build": "npm run build-main && npm run build-renderer",
    "build-main": "cross-env NODE_ENV=production webpack --config webpack-main-PROD-config.js",
    "build-renderer": "cross-env NODE_ENV=production webpack --config webpack-renderer-PROD-config.js",
    "start-dev": "cross-env START_HOT=1 npm run start-renderer-dev",
    "start-main-dev": "webpack --config webpack-main-config.js && electron ./dist/main.js",
    "start-renderer-dev": "webpack-dev-server --config webpack-renderer-DEV-config.js",
    "prestart": "npm run build",
    "start": "electron .",
    "lint": "tslint '{src,test,mocks}/**/*.{ts,tsx}' --project ./tsconfig.json",
    "test": "jest '(\\/test\\/(?!e2e/)).*'",
    "pretest:e2e": "npm run build",
    "test:e2e": "jest '(\\/test\\/e2e/).*'",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testRegex": "(/test/.+\\.spec)\\.tsx?$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "json",
      "node"
    ],
    "moduleNameMapper": {
      "\\.(jpe?g|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/mocks/fileMock.js",
      "\\.(s?css|sass)$": "<rootDir>/mocks/styleMock.js"
    }
  },
  "build": {
    "productName": "AetherMail",
    "appId": "com.aurailus.aethermail",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/",
      "node_modules/",
      "package.json"
    ],
    "linux": {
      "target": "deb",
      "category": "Network"
    },
    "win": {
      "target": "nsis"
    }
  },
  "author": {
    "name": "Nicole Collings",
    "email": "me@auri.xyz"
  },
  "license": "SEE LICENSE IN LICENSE.MD",
  "bugs": {
    "url": "https://github.com/Aurailus/Aether/issues"
  },
  "homepage": "https://github.com/Aurailus/Aether",
  "repository": "https://github.com/Aurailus/Aether",
  "optionalDependencies": {
    "fsevents": "^2.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.9.6",
    "@babel/plugin-proposal-class-properties": "^7.8.3",
    "@babel/polyfill": "^7.8.7",
    "@babel/preset-env": "^7.9.6",
    "@babel/preset-react": "^7.9.4",
    "@babel/preset-typescript": "^7.9.0",
    "@hot-loader/react-dom": "^16.13.0",
    "@types/electron-devtools-installer": "^2.2.0",
    "@types/jest": "^25.2.1",
    "@types/mailparser": "^2.7.2",
    "@types/node": "^13.13.4",
    "@types/quoted-printable": "^0.2.2",
    "@types/react": "^16.9.34",
    "@types/react-addons-css-transition-group": "^15.0.5",
    "@types/react-dom": "^16.9.7",
    "@types/react-hot-loader": "^4.1.1",
    "@types/react-redux": "^7.1.7",
    "@types/react-test-renderer": "^16.9.2",
    "@types/webpack": "^4.41.12",
    "@types/webpack-env": "^1.15.2",
    "babel-loader": "^8.1.0",
    "cross-env": "^7.0.2",
    "css-loader": "^3.5.3",
    "electron": "^9.4.0",
    "electron-builder": "^22.6.0",
    "electron-devtools-installer": "^3.0.0",
    "electron-rebuild": "^1.10.1",
    "file-loader": "^4.3.0",
    "fork-ts-checker-webpack-plugin": "^4.1.3",
    "html-webpack-plugin": "^4.3.0",
    "image-webpack-loader": "^6.0.0",
    "jest": "^25.5.3",
    "lint-staged": "^10.2.2",
    "node-sass": "^4.14.0",
    "prettier": "^2.0.5",
    "react-hot-loader": "^4.12.21",
    "react-test-renderer": "^16.13.1",
    "redux-devtools-extension": "^2.13.8",
    "sass-loader": "^8.0.2",
    "source-map-loader": "^0.2.4",
    "spectron": "^10.0.1",
    "style-loader": "^1.2.1",
    "typescript": "^3.8.3",
    "webpack": "^4.43.0",
    "webpack-cli": "^3.3.11",
    "webpack-dev-server": "^3.10.3",
    "webpack-merge": "^4.2.2"
  },
  "dependencies": {
    "@types/email-addresses": "^3.0.0",
    "@types/marked": "^0.7.4",
    "@types/sha256": "^0.2.0",
    "@types/turndown": "^5.0.0",
    "email-addresses": "^3.1.0",
    "imap": "^0.8.19",
    "jsdom": "^16.2.2",
    "knex": "^0.21.1",
    "mailparser": "^2.7.7",
    "marked": "^1.0.0",
    "quoted-printable": "^1.0.1",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-redux": "^7.2.0",
    "react-transition-group": "^4.3.0",
    "sha256": "^0.2.0",
    "sqlite3": "^4.2.0",
    "tedious": "^8.3.0",
    "turndown": "^6.0.0"
  }
}
